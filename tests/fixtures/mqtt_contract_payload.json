    "disconnected_after_data": {
      "description": "The safety-critical GATE state: a broker that connected, collected live topics, then dropped. status is error and BOTH connected_age_s and subscribed_age_s are null (we can no longer vouch), but the topics SURVIVE the drop with their growing last-observed ages -- the server anchors staleness to last_live_seen_age_s while treating the broker as failed, and must NOT fire a freshness alarm the instant a broker blips (the disconnect envelope is the signal). Events: connect -> two live messages -> disconnect -> snapshot.",
      "config": [
        {
          "broker_id": "plant-mqtt",
          "host": "plant.internal",
          "port": 8883,
          "tls": true,
          "username": "fivenines",
          "password": "s3cr3t",
          "monitors": [
            {"id": "reactors", "topic_filter": "plant/+/temp", "capture_payload": true}
          ]
        }
      ],
      "events": [
        {"at": 7000.0, "type": "connect", "reason": "Success"},
        {"at": 7005.0, "type": "message", "topic": "plant/reactor1/temp", "payload": "300", "retain": false},
        {"at": 7010.0, "type": "message", "topic": "plant/reactor2/temp", "payload": "305", "retain": false},
        {"at": 7020.0, "type": "disconnect", "reason": "Keep alive timeout"}
      ],
      "snapshot_at": 7040.0,
      "payload": {
        "brokers": {
          "plant-mqtt": {
            "status": "error",
            "error": "disconnected: Keep alive timeout",
            "connected_age_s": null,
            "monitors": {
              "reactors": {
                "subscribed_age_s": null,
                "capped": false,
                "topics": {
                  "plant/reactor1/temp": {
                    "first_seen_age_s": 35.0,
                    "last_message_age_s": 35.0,
                    "last_live_seen_age_s": 35.0,
                    "last_payload": "300",
                    "last_payload_retained": false
                  },
                  "plant/reactor2/temp": {
                    "first_seen_age_s": 30.0,
                    "last_message_age_s": 30.0,
                    "last_live_seen_age_s": 30.0,
                    "last_payload": "305",
                    "last_payload_retained": false
                  }
                }
              }
            }
          }
        }
      }
