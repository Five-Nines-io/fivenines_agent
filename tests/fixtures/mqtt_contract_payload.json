{
  "description": "Shared MQTT contract fixture between fivenines-agent and fivenines-server. Source of truth: fivenines-agent tests/fixtures/mqtt_contract_payload.json, asserted end-to-end by tests/test_mqtt.py::test_contract_fixture_round_trip (paho's Client is mocked; each scenario's 'events' are replayed against a real MQTTManager under a deterministic clock, and manager.snapshot() at 'snapshot_at' must equal 'payload'). The server's spec posts each 'payload' under data['mqtt'] through /collect and asserts Ingesters::Agent ingests it. 'config' is the shape config['mqtt'] takes (a list of brokers). 'events' and 'max_topics' are agent-side replay inputs the server ignores. Ages are seconds (floats) computed as snapshot_at minus the recorded monotonic mark; the server anchors everything to its own received_at, so these are relative, not timestamps. Absence semantics (server-side rule, no agent-visible payload -- so pinned here, not as a scenario): the whole data['mqtt'] key is ABSENT both when the feature is unconfigured AND when the collector raises (the agent's per-collector wrapper swallows the exception and emits nothing), so the server disambiguates 'unconfigured' from 'collection failed' only from what it configured, and must never synthesize a healthy-empty shape for a configured host that reported no key. Likewise a broker whose client construction fails is OMITTED from the 'brokers' map (the key is present, that broker_id is not) -- treat a configured-but-missing broker_id as collection-failed, never as removed. A broker that connected then dropped is NOT absent: it reports a status:error envelope with its topics retained (see disconnected_after_data) so staleness alarms stay gated. Change only in lockstep across both repos.",
  "agent_min_version": "1.12.0",
  "scenarios": {
    "healthy_multi_topic": {
      "description": "A reachable broker, one monitor, two concrete topics fed by live (RETAIN=0) messages. last_live_seen_age_s tracks the newest live delivery; payloads are captured.",
      "config": [
        {
          "broker_id": "prod-emqx",
          "host": "emqx.factory.internal",
          "port": 8883,
          "tls": true,
          "username": "fivenines",
          "password": "s3cr3t",
          "monitors": [
            {"id": "line-status", "topic_filter": "factory/+/status", "capture_payload": true}
          ]
        }
      ],
      "events": [
        {"at": 1000.0, "type": "connect", "reason": "Success"},
        {"at": 1002.0, "type": "message", "topic": "factory/line1/status", "payload": "RUNNING", "retain": false},
        {"at": 1004.0, "type": "message", "topic": "factory/line2/status", "payload": "IDLE", "retain": false},
        {"at": 1050.0, "type": "message", "topic": "factory/line1/status", "payload": "RUNNING", "retain": false}
      ],
      "snapshot_at": 1060.0,
      "payload": {
        "brokers": {
          "prod-emqx": {
            "status": "connected",
            "error": null,
            "connected_age_s": 60.0,
            "monitors": {
              "line-status": {
                "subscribed_age_s": 60.0,
                "capped": false,
                "topics": {
                  "factory/line1/status": {
                    "first_seen_age_s": 58.0,
                    "last_message_age_s": 10.0,
                    "last_live_seen_age_s": 10.0,
                    "last_payload": "RUNNING",
                    "last_payload_retained": false
                  },
                  "factory/line2/status": {
                    "first_seen_age_s": 56.0,
                    "last_message_age_s": 56.0,
                    "last_live_seen_age_s": 56.0,
                    "last_payload": "IDLE",
                    "last_payload_retained": false
                  }
                }
              }
            }
          }
        }
      }
    },
    "retained_only": {
      "description": "The Uptime-Kuma anti-pattern we refuse to ship: a topic seen ONLY via a RETAIN=1 replay. last_payload is present (fresh stored state) but last_live_seen_age_s is null -- a stored status is not proof the device is alive.",
      "config": [
        {
          "broker_id": "iot-hub",
          "host": "10.20.0.5",
          "port": 1883,
          "tls": false,
          "monitors": [
            {"id": "room-temp", "topic_filter": "home/+/temperature", "capture_payload": true}
          ]
        }
      ],
      "events": [
        {"at": 2000.0, "type": "connect", "reason": "Success"},
        {"at": 2001.0, "type": "message", "topic": "home/kitchen/temperature", "payload": "21.5", "retain": true}
      ],
      "snapshot_at": 2030.0,
      "payload": {
        "brokers": {
          "iot-hub": {
            "status": "connected",
            "error": null,
            "connected_age_s": 30.0,
            "monitors": {
              "room-temp": {
                "subscribed_age_s": 30.0,
                "capped": false,
                "topics": {
                  "home/kitchen/temperature": {
                    "first_seen_age_s": 29.0,
                    "last_message_age_s": 29.0,
                    "last_live_seen_age_s": null,
                    "last_payload": "21.5",
                    "last_payload_retained": true
                  }
                }
              }
            }
          }
        }
      }
    },
