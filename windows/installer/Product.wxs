<?xml version="1.0" encoding="UTF-8"?>
<!--
  Fivenines Monitoring Agent MSI installer.

    - Install to %ProgramFiles%\fivenines-agent (admin-write-only by default).
    - Create config dir at %ProgramData%\fivenines_agent with a restrictive ACL.
    - Bundle the agent binary, the WinSW wrapper (renamed), and WinSW XML.
    - Register the Windows Service via the bundled WinSW exe.
    - Accept the enrollment token via the TOKEN MSI property (hidden, D21);
      a deferred custom action writes it to the config dir with a tight ACL
      (F1) and runs the WMI Storage-namespace delegation (D19).
    - Service runs as a dedicated low-privilege account, added to the
      Performance Monitor Users group by the MSI (D12). Account name and
      password are SERVICEACCOUNT / SERVICEACCOUNTPASSWORD properties.
    - Major upgrades are clean (UpgradeCode kept stable); uninstall removes
      the service, config dir, and logs.

  This file is WiX 5 syntax. The Windows CI runner (T14) builds the MSI with
  the WiX 5 toolset. Source variables:
    Version           = the agent version (from pyproject.toml). MSI's Package
                        Version drives the ARP DisplayVersion and the
                        MajorUpgrade comparison; binding !(bind.FileVersion)
                        against the PyInstaller bootloader yields an empty
                        string because the frozen exe has no Win32 version
                        resource.
    AgentBinarySource = the PyInstaller onedir OUTPUT DIRECTORY
                        (e.g. dist/windows/fivenines-agent-windows-amd64/).
                        The MSI ships the .exe AND the _internal/ subdir
                        (python311.dll, base_library.zip, all bundled DLLs).
                        Shipping only the .exe yields PYI-ERROR at start:
                        "Failed to load Python DLL ... module could not be found".
    WinSwSource       = path to the WinSW.NET4.exe download.
    WinSwConfigSource = path to windows/winsw/fivenines-agent.xml.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="Fivenines Monitoring Agent"
           Manufacturer="Five-Nines.io"
           Version="$(var.Version)"
           UpgradeCode="A2D5E1F0-1234-5678-90AB-CDEF12345678"
           Scope="perMachine"
           InstallerVersion="500">

    <SummaryInformation Description="Fivenines Monitoring Agent Installer" />

    <!-- Major upgrade: same UpgradeCode auto-replaces older versions cleanly. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Fivenines Agent is already installed." />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Enrollment token: Hidden="yes" keeps it out of installer logs;
         Secure="yes" lets it be passed through to deferred custom actions
         (D21 / Section 3 F1). -->
    <Property Id="TOKEN" Secure="yes" Hidden="yes" />

    <!-- Service account properties. The MSI's CreateServiceAccount CA
         provisions [ComputerName]\fivenines-agent (creating it if absent,
         generating a random password). Operators with config-management
         tooling can pre-stage an account and pass SERVICEACCOUNT +
         SERVICEACCOUNTPASSWORD on the msiexec command line to override.
         SERVICEACCOUNT default is left empty; the SetProperty action below
         resolves [ComputerName] into a concrete machine\name string before
         any CustomActionData propagation. Property-table defaults are NOT
         recursively formatted - storing "[ComputerName]\fivenines-agent"
         as the default yields a literal value that gets passed through to
         deferred CAs as the unresolved bracket-token, breaking SID lookups
         in our PowerShell scripts. -->
    <Property Id="SERVICEACCOUNT" />
    <Property Id="SERVICEACCOUNTPASSWORD" Secure="yes" Hidden="yes" />

    <!-- Resolve [ComputerName] before any CA reads SERVICEACCOUNT.
         Sequence="both" so this runs in InstallUI and InstallExecute alike;
         Before="CostFinalize" puts it ahead of the CustomActionData-building
         SetProperty actions for CreateServiceAccount/WriteTokenAcl/DelegateWmi. -->
    <SetProperty Id="SERVICEACCOUNT"
                 Value="[ComputerName]\fivenines-agent"
                 Before="CostFinalize"
                 Sequence="both"
                 Condition="NOT SERVICEACCOUNT" />

    <Property Id="ARPCONTACT" Value="sebastien@fivenines.io" />
    <Property Id="ARPHELPLINK" Value="https://docs.fivenines.io/agent" />
    <Property Id="ARPURLINFOABOUT" Value="https://fivenines.io" />

    <!-- Install layout. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="fivenines-agent" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="CONFIGDIR" Name="fivenines_agent">
        <Directory Id="LOGDIR" Name="logs" />
      </Directory>
    </StandardDirectory>

    <!-- Components: agent binary + the entire PyInstaller _internal/ payload,
         WinSW (renamed for stable service path), WinSW XML config, custom-
         action PS scripts. -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="AgentBinary">
        <File Id="AgentExe"
              Source="$(var.AgentBinarySource)\fivenines-agent-windows-amd64.exe"
              Name="fivenines-agent-windows-amd64.exe"
              KeyPath="yes" />
      </Component>

      <!-- Harvest the full PyInstaller onedir payload (_internal\) so the
           bootloader can find python311.dll + base_library.zip + all the
           hidden-import DLLs. Without this the exe starts and immediately
           fails with PYI-ERROR "Failed to load Python DLL ... The specified
           module could not be found", which is actually a missing-payload
           problem - the file does exist relative to the install dir, but
           its dependencies in _internal\ don't because we didn't ship them.
           Files Subdirectory places the harvested entries under
           INSTALLFOLDER\_internal\ to match the on-disk layout. -->
      <Files Subdirectory="_internal" Include="$(var.AgentBinarySource)\_internal\**" />


      <Component Id="WinSwBinary">
        <!-- WinSW renamed so the registered service ImagePath is stable
             across upgrades; WinSW reads its XML from <name>.xml next to
             itself, so the XML below uses the same base name. -->
        <File Id="WinSwExe"
              Source="$(var.WinSwSource)"
              Name="fivenines-agent-service.exe"
              KeyPath="yes" />

        <!-- Register service via MSI's ServiceInstall (rather than calling
             WinSW's install command in a custom action) - cleaner integration
             with the MSI rollback machinery.

             We intentionally do NOT set Account/Password here. The service
             is registered with LocalSystem as a placeholder; immediately
             after InstallServices, the CreateServiceAccount custom action
             provisions the dedicated low-priv account (auto-generating a
             random password if the deployer didn't supply one) and runs
             'sc.exe config' to flip the service to that account. The window
             during which the service is configured as LocalSystem is bounded
             by a single MSI execute pass and we don't auto-start, so the
             service never actually runs as LocalSystem. -->
        <ServiceInstall Id="FivninesAgentService"
                        Type="ownProcess"
                        Name="fivenines-agent"
                        DisplayName="Fivenines Monitoring Agent"
                        Description="Collects server metrics and reports them to the fivenines API."
                        Start="auto"
                        ErrorControl="normal"
                        Vital="yes" />

        <!-- Intentionally NO Start="install": the deferred custom actions
             (WriteTokenAcl, DelegateWmi) run AFTER InstallServices, so if
             we asked the SCM to start the service here via the standard
             StartServices action, the agent would try to read TOKEN before
             it has been written and exit immediately - WinSW would then
             restart-loop and the MSI would hang waiting for Running. The
             StartAgentService custom action below is sequenced after
             DelegateWmi (TOKEN written, WMI delegated) and uses sc.exe
             which is fire-and-forget so the MSI never hangs. -->
        <ServiceControl Id="ControlAgentService"
                        Name="fivenines-agent"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>

      <Component Id="WinSwConfig">
        <File Id="WinSwXml"
              Source="$(var.WinSwConfigSource)"
              Name="fivenines-agent-service.xml"
              KeyPath="yes" />
      </Component>

      <Component Id="SetTokenAclScript">
        <File Id="SetTokenAclPs1"
              Source="SetTokenFileAcl.ps1"
              Name="SetTokenFileAcl.ps1"
              KeyPath="yes" />
      </Component>

      <Component Id="DelegateWmiScript">
        <File Id="DelegateWmiPs1"
              Source="DelegateWmiStorageNamespace.ps1"
              Name="DelegateWmiStorageNamespace.ps1"
              KeyPath="yes" />
      </Component>

      <Component Id="CreateServiceAccountScript">
        <File Id="CreateServiceAccountPs1"
              Source="CreateServiceAccount.ps1"
              Name="CreateServiceAccount.ps1"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Config + log dirs with a restrictive ACL: only well-known principals
         (Administrators, SYSTEM) here, because util:PermissionEx runs during
         InstallFiles - that's BEFORE CreateServiceAccount has provisioned
         [SERVICEACCOUNT] and therefore before LookupAccountName can resolve
         it. The service account's grant is added afterwards by
         CreateServiceAccount.ps1 via icacls. util:PermissionEx replaces the
         inherited ProgramData ACL (which would otherwise give BUILTIN\Users
         read access), so even if our CA were to fail we don't degrade to a
         world-listable config dir. -->
    <ComponentGroup Id="ConfigDirComponents" Directory="CONFIGDIR">
      <Component Id="ConfigDirComponent">
        <CreateFolder>
          <util:PermissionEx User="Administrators" GenericAll="yes" />
          <util:PermissionEx User="SYSTEM" GenericAll="yes" />
        </CreateFolder>
        <RemoveFolder Id="RemoveConfigDir" On="uninstall" />
        <!-- Required: every Component needs a KeyPath -->
        <RegistryValue Root="HKLM"
                       Key="Software\Five-Nines.io\fivenines-agent"
                       Name="ConfigDirInstalled"
                       Value="1"
                       Type="integer"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="LogDirComponents" Directory="LOGDIR">
      <Component Id="LogDirComponent">
        <CreateFolder>
          <util:PermissionEx User="Administrators" GenericAll="yes" />
          <util:PermissionEx User="SYSTEM" GenericAll="yes" />
        </CreateFolder>
        <RemoveFolder Id="RemoveLogDir" On="uninstall" />
        <RegistryValue Root="HKLM"
                       Key="Software\Five-Nines.io\fivenines-agent"
                       Name="LogDirInstalled"
                       Value="1"
                       Type="integer"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Custom actions for the post-install security work. Deferred + no
         impersonation so they run with SYSTEM rights against the just-created
         service account and namespace. Token is passed through CustomActionData
         as a JSON-ish blob so the deferred action sees TOKEN even though it
         runs out-of-process. -->
    <!-- WixQuietExec requires the command string to start with a QUOTED
         application name (per the WiX 4 docs). The deferred custom action
         pattern reads the CustomActionData (set by the matching SetProperty
         above) as its command line; the SetProperty's Id MUST match the
         CustomAction Id so the runtime can find the value. -->
    <!-- [CONFIGDIR] expands to a path ending in '\'. Quoting "...\fivenines_agent\"
         would close with `\"`, which Windows command-line parsing treats as an
         escaped quote - PowerShell then sees malformed args, drops to its REPL,
         and hangs waiting for stdin. The standard WixQuietExec recipe is to
         append '.' so the value resolves to "...\fivenines_agent\." (closing
         quote is preceded by '.', not '\'). The PS script accepts the trailing
         '\.' just fine - it joins TOKEN onto it normally. -->
    <!-- Provision the dedicated service account (creates it + random password
         if needed, group memberships, SeServiceLogonRight, sc.exe config flip)
         immediately after InstallServices. Must run BEFORE WriteTokenAcl and
         DelegateWmi since those both look up [SERVICEACCOUNT]'s SID. -->
    <SetProperty Id="CreateServiceAccount"
                 Value="&quot;powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[#CreateServiceAccountPs1]&quot; -ServiceAccount &quot;[SERVICEACCOUNT]&quot; -Password &quot;[SERVICEACCOUNTPASSWORD]&quot;"
                 Before="CreateServiceAccount"
                 Sequence="execute" />
    <CustomAction Id="CreateServiceAccount"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64" />

    <SetProperty Id="WriteTokenAcl"
                 Value="&quot;powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[#SetTokenAclPs1]&quot; -ConfigDir &quot;[CONFIGDIR].&quot; -ServiceAccount &quot;[SERVICEACCOUNT]&quot; -Token &quot;[TOKEN]&quot;"
                 Before="WriteTokenAcl"
                 Sequence="execute" />
    <CustomAction Id="WriteTokenAcl"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64" />

    <SetProperty Id="DelegateWmi"
                 Value="&quot;powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[#DelegateWmiPs1]&quot; -ServiceAccount &quot;[SERVICEACCOUNT]&quot;"
                 Before="DelegateWmi"
                 Sequence="execute" />
    <CustomAction Id="DelegateWmi"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  BinaryRef="Wix4UtilCA_X64" />

    <!-- Start the service after TOKEN write and WMI delegation are done.
         sc.exe start returns as soon as the SCM accepts the start request
         (fire-and-forget), so a crash-looping agent cannot hang the MSI.
         Return="ignore" so a transient start failure does not roll back a
         successful install - the operator can Start-Service manually and
         see WinSW logs. -->
    <SetProperty Id="StartAgentService"
                 Value="&quot;sc.exe&quot; start fivenines-agent"
                 Before="StartAgentService"
                 Sequence="execute" />
    <CustomAction Id="StartAgentService"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  BinaryRef="Wix4UtilCA_X64" />

    <InstallExecuteSequence>
      <!-- Sequence the post-install CAs:
             1. CreateServiceAccount: provision the dedicated low-priv account
                (or validate an operator-supplied one) and flip the service
                from the LocalSystem placeholder to that account.
             2. WriteTokenAcl: write TOKEN under the config dir with an ACL
                that grants only the (now-existing) service account + admins
                + SYSTEM.
             3. DelegateWmi: grant the service account read on the WMI Storage
                namespace so the disk-health collector works without admin.
             4. StartAgentService: now that the service account, TOKEN, and
                WMI delegation are all in place, kick the service. Bootstraps
                (fivenines_setup.ps1, fivenines_update.ps1) still call
                Start-Service afterwards for idempotency. -->
      <Custom Action="CreateServiceAccount" After="InstallServices" Condition="NOT Installed" />
      <Custom Action="WriteTokenAcl" After="CreateServiceAccount" Condition="NOT Installed" />
      <Custom Action="DelegateWmi" After="WriteTokenAcl" Condition="NOT Installed" />
      <Custom Action="StartAgentService" After="DelegateWmi" Condition="NOT Installed" />
    </InstallExecuteSequence>

    <Feature Id="MainFeature" Title="Fivenines Agent" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="ConfigDirComponents" />
      <ComponentGroupRef Id="LogDirComponents" />
    </Feature>

  </Package>
</Wix>
