FROM python:3.9-buster

# Debian Buster armv6hf via --platform linux/arm/v6 (glibc 2.28, RPi OS Buster+)
# No libvirt needed for RPi/embedded devices

RUN apt-get update && apt-get install -y \
    gcc g++ make pkg-config wget \
    libxml2-dev libffi-dev libssl-dev zlib1g-dev \
    binutils patchelf \
    && rm -rf /var/lib/apt/lists/*

ENV TARGET_ARCH="arm"
WORKDIR /workspace
CMD ["bash"]
