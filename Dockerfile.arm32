FROM python:3.9-bullseye

# Debian Bullseye armhf via --platform linux/arm/v7 (glibc 2.31, RPi OS Bullseye+)
# Covers Pi 2, Pi 3, Pi 4, Pi Zero 2 W, and all armv7+ devices
# No libvirt needed for RPi/embedded devices

RUN apt-get update && apt-get install -y \
    gcc g++ make pkg-config wget \
    libxml2-dev libffi-dev libssl-dev zlib1g-dev \
    binutils patchelf \
    && rm -rf /var/lib/apt/lists/*

ENV TARGET_ARCH="arm"
WORKDIR /workspace

# Pre-install Python dependencies in the Docker image so they are cached
# across builds. Only rebuilds when pyproject.toml or poetry.lock change.
# The venv lives at /opt/venv (not /workspace) because CI bind-mounts
# the repo checkout over /workspace at runtime.

COPY pyproject.toml poetry.lock ./

# Strip libvirt-python and proxmoxer (not needed on RPi/embedded)
RUN sed -i '/libvirt-python/d' pyproject.toml && \
    sed -i '/proxmoxer/d' pyproject.toml

# Create venv and install Poetry + dependencies
RUN python -m venv /opt/venv && \
    . /opt/venv/bin/activate && \
    python -m pip install --upgrade pip setuptools wheel && \
    python -m pip install poetry==2.2.1 pyinstaller && \
    poetry config virtualenvs.create false && \
    poetry config installer.max-workers 1 && \
    poetry lock --no-interaction && \
    poetry install --no-interaction && \
    pip uninstall -y systemd-watchdog 2>/dev/null || true

CMD ["bash"]
