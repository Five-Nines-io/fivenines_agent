FROM python:3.9-bullseye

# Debian Bullseye armhf via --platform linux/arm/v7 (glibc 2.31, RPi OS Bullseye+)
# Covers Pi 2, Pi 3, Pi 4, Pi Zero 2 W, and all armv7+ devices
# No libvirt needed for RPi/embedded devices

RUN apt-get update && apt-get install -y \
    gcc g++ make pkg-config wget \
    libxml2-dev libffi-dev libssl-dev zlib1g-dev \
    binutils patchelf \
    && rm -rf /var/lib/apt/lists/*

ENV TARGET_ARCH="arm"
WORKDIR /workspace
CMD ["bash"]
